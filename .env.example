# =============================================
#  SUPABASE CONFIGURATION
# =============================================
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# =============================================
#  DATABASE (Supabase PostgreSQL)
# =============================================
# Session Pooler - recommended for Windows/IPv4
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_ID:YOUR_DB_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres?pgbouncer=true"

# =============================================
#  JWT & SERVER
# =============================================
JWT_SECRET=your_long_random_jwt_secret_here
PORT=5000

# =============================================
#  ADMIN DASHBOARD (Next.js)
# =============================================
NEXT_PUBLIC_API_URL=http://127.0.0.1:5000/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# =============================================
#  FIREBASE
# =============================================
FIREBASE_PROJECT_ID=your_firebase_project_id

# =============================================
#  MOBILE APP (React Native)
# =============================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# =============================================
#  VERCEL BLOB
# =============================================
BLOB_READ_WRITE_TOKEN="your_vercel_blob_token_here"

# =============================================
#  KEEP ALIVE SYSTEM  ← MANDATORY
# =============================================
# Protects the GET /api/system/keep-alive endpoint used by cron-job.org
# to prevent the Supabase Free Plan database from pausing due to inactivity.
#
# Generate a secure value with:
#   node -e "require('crypto').randomBytes(48).toString('hex')"
#
# Add this same value to:
#   - Your local .env
#   - Vercel Environment Variables (Production)
#   - cron-job.org custom request header: Authorization: Bearer <value>
KEEP_ALIVE_SECRET=generate-a-long-random-secret-at-least-64-chars
