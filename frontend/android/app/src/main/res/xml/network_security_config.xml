<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext HTTP traffic for all local/private network ranges during development -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Metro bundler / emulator loopback -->
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">10.0.3.2</domain>

        <!-- Standard private network ranges (works regardless of which WiFi you're on) -->
        <domain includeSubdomains="true">10.0.0.0</domain>
        <domain includeSubdomains="true">10.0.0.1</domain>
        <domain includeSubdomains="true">10.248.116.154</domain>
        <domain includeSubdomains="true">10.34.82.154</domain>
        <domain includeSubdomains="true">192.168.1.0</domain>
        <domain includeSubdomains="true">192.168.0.0</domain>
    </domain-config>

    <!-- Base config: allow cleartext to any 10.x.x.x address (covers any office/home LAN) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
